{
    "name": "bou",
    "version": "1.0.0",
    "description": "A HAM Application",
    "type": "module",
    "scripts": {
        "ham:build": "ham build && rimraf public/components",
        "dev": "concurrently \"nodemon --watch src -e html,lhtml,css,ts --exec \\\"npm run ham:build\\\"\" \"rollup -c -w\" \"vite\"",
        "build": "npm run ham:build && rollup -c && vite build && xcopy /E /I /Y public\\assets dist\\assets",
        "build-all": "npm run build",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^26.0.1",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@types/aos": "^3.0.7",
        "@types/node": "^25.5.0",
        "concurrently": "^9.2.1",
        "glob": "^11.0.0",
        "nodemon": "^3.1.14",
        "rimraf": "^6.1.3",
        "rollup": "3.17.3",
        "rollup-plugin-copy": "3.4.0",
        "rollup-plugin-typescript2": "^0.36.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "vite": "^8.0.2"
    },
    "dependencies": {
        "@vercel/analytics": "^2.0.1",
        "aos": "^2.3.4"
    }
}
